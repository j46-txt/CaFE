# ===================================================
# OPTIONAL CONFIGURATION FOR CLOUD BACKUP & SECURITY
# ===================================================
# 
# NOTE: If you want to run the app locally, IGNORE this file. 
# Without a `.env` file, the app defaults to local SQLite mode automatically.
#
# CLOUD BACKUP BEHAVIOR:
# - This app uses a remote PostgreSQL database solely as a backup vault for the SQLite file.
# - Useful for ephemeral cloud hosting (like Render, Railway, Heroku) where local disks are wiped on restart, or for syncing data across different machines.
# - CRITICAL: Requires SEQUENTIAL usage (one instance at a time) to avoid data overwrite.
# ===================================================

# PostgreSQL Connection URL
# Works with any Postgres provider (e.g., Neon, Supabase, Railway, AWS RDS, etc.)
DATABASE_URL=postgres://user:password@your-postgres-host.com/dbname?sslmode=require

# Web Access Security Key (URL Authentication)
# Since cloud deployments are accessible via public URLs, this key prevents unauthorized internet users from accessing your application.
# When configured, you must access the app using the `key` parameter in the URL (Example: https://your-app-name.onrender.com/?key=YOUR_SECRET_KEY)
ACCESS_KEY=your_secret_access_key_here
